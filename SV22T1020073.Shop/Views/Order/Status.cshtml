@model SV22T1020073.Models.Sales.OrderViewInfo
@{
    ViewData["Title"] = $"Chi tiết đơn hàng #{Model.OrderID}";
    var details = ViewBag.Details as List<SV22T1020073.Models.Sales.OrderDetailViewInfo> ?? new List<SV22T1020073.Models.Sales.OrderDetailViewInfo>();
    decimal total = details.Sum(d => d.TotalPrice);

    var steps = new[] {
        new { Name = "Đã đặt", Icon = "fa-shopping-bag", Time = (DateTime?)Model.OrderTime, Done = true, Active = false },
        new { Name = "Đã duyệt", Icon = "fa-clipboard-check", Time = Model.AcceptTime, Done = Model.AcceptTime.HasValue, Active = Model.AcceptTime.HasValue && !Model.ShippedTime.HasValue },
        new { Name = "Đang giao", Icon = "fa-truck", Time = Model.ShippedTime, Done = Model.ShippedTime.HasValue, Active = Model.ShippedTime.HasValue && !Model.FinishedTime.HasValue },
        new { Name = "Hoàn tất", Icon = "fa-check-circle", Time = Model.FinishedTime, Done = Model.FinishedTime.HasValue && Model.Status == SV22T1020073.Models.Sales.OrderStatusEnum.Completed, Active = false }
    };

    if (Model.Status == SV22T1020073.Models.Sales.OrderStatusEnum.Cancelled || Model.Status == SV22T1020073.Models.Sales.OrderStatusEnum.Rejected)
    {
        steps = new[] {
            new { Name = "Đã đặt", Icon = "fa-shopping-bag", Time = (DateTime?)Model.OrderTime, Done = true, Active = false },
            new { Name = "Đã duyệt", Icon = "fa-clipboard-check", Time = Model.AcceptTime, Done = Model.AcceptTime.HasValue, Active = false },
            new { Name = Model.Status == SV22T1020073.Models.Sales.OrderStatusEnum.Cancelled ? "Đã hủy" : "Từ chối", Icon = "fa-times-circle", Time = Model.FinishedTime, Done = true, Active = false }
        };
    }
}

<div class="shop-page-wrapper animate-in">
    <!-- Page Header -->
    <div class="d-flex align-items-center gap-3 mb-5">
        <a href="/Order/History" class="shop-btn-icon shadow-sm" style="width: 48px; height: 48px; border-radius: 14px; display: flex; align-items: center; justify-content: center; background: white; border: 2px solid var(--shop-primary); color: var(--shop-primary);">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div>
            <h1 class="display-6 fw-black mb-1" style="font-family: 'Inter', sans-serif;">
                Đơn hàng <span class="text-primary">#@Model.OrderID</span>
            </h1>
            <p class="text-muted small mb-0">Đặt lúc @Model.OrderTime.ToString("HH:mm") ngày @Model.OrderTime.ToString("dd/MM/yyyy")</p>
        </div>
        <div class="ms-auto">
             <span class="badge rounded-pill bg-warning text-dark px-3 py-2 fw-bold" style="font-size: 0.85rem;">
                <i class="fas fa-info-circle me-1"></i> @Model.StatusDescription
             </span>
        </div>
    </div>

    <!-- Timeline Tracking -->
    <div class="shop-card border-0 shadow-sm mb-4">
        <div class="p-4 overflow-auto">
            <div class="shop-timeline-premium">
                @foreach (var step in steps)
                {
                    <div class="timeline-item @(step.Done ? "completed" : "") @(step.Active ? "active" : "")">
                        <div class="timeline-connector"></div>
                        <div class="timeline-icon-box shadow-sm">
                            <i class="fas @step.Icon"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-title fw-bold">@step.Name</div>
                            <div class="timeline-time text-muted">
                                @if (step.Done && step.Time.HasValue)
                                {
                                    @step.Time.Value.ToString("HH:mm dd/MM")
                                }
                                else
                                {
                                    @("---")
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Order Items -->
        <div class="col-lg-8">
            <div class="shop-card border-0 shadow-sm">
                <div class="p-4 border-bottom bg-light bg-opacity-30 d-flex align-items-center justify-content-between">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-shopping-basket me-2 text-primary"></i>
                        Sản phẩm đã chọn (@details.Count)
                    </h5>
                    @if (Model.Status == SV22T1020073.Models.Sales.OrderStatusEnum.Completed)
                    {
                        <a href="/Order/Reorder/@Model.OrderID" class="shop-btn-primary px-3 py-1 rounded-pill small">
                            <i class="fas fa-redo me-1"></i> Mua lại đơn này
                        </a>
                    }
                </div>
                <div class="p-0">
                    <div class="table-responsive">
                        <table class="table mb-0 align-middle">
                            <thead class="bg-light">
                                <tr style="font-size: 0.75rem; text-transform: uppercase; color: #64748b;">
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in details)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="rounded-3 border overflow-hidden" style="width: 56px; height: 56px; background: white;">
                                                    <img src="@(string.IsNullOrEmpty(d.Photo) ? "https://placehold.co/100x100/e2e8f0/3b82f6?text=P" : (d.Photo.StartsWith("http") ? d.Photo : Url.Content("~/images/products/" + d.Photo)))" 
                                                         class="w-100 h-100" style="object-fit: cover;">
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">@d.ProductName</div>
                                                    <div class="small text-muted">@d.Unit</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold">@d.Quantity</td>
                                        <td class="text-end text-muted small">@d.SalePrice.ToString("N0") đ</td>
                                        <td class="text-end pe-4 fw-black text-dark">@d.TotalPrice.ToString("N0") đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="d-flex flex-column gap-4">
                <!-- Delivery Info -->
                <div class="shop-card border-0 shadow-sm overflow-hidden">
                    <div class="p-4" style="background: linear-gradient(135deg, var(--shop-primary) 0%, var(--shop-primary-dark) 100%);">
                        <h6 class="text-white small fw-bold text-uppercase opacity-75 mb-3">Thông tin nhận hàng</h6>
                        <div class="d-flex align-items-center gap-3 text-white mb-2">
                             <div class="rounded-circle bg-white bg-opacity-20 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="fas fa-map-marker-alt"></i>
                             </div>
                             <div>
                                <div class="fw-bold">@Model.DeliveryAddress</div>
                                <div class="small opacity-90">@Model.DeliveryProvince</div>
                             </div>
                        </div>
                    </div>
                    <div class="p-4">
                         <div class="d-flex justify-content-between mb-2">
                             <span class="text-muted small">Tên người nhận</span>
                             <span class="fw-bold">@Model.CustomerName</span>
                         </div>
                         <div class="d-flex justify-content-between">
                             <span class="text-muted small">Số điện thoại</span>
                             <span class="fw-bold">@Model.CustomerPhone</span>
                         </div>
                    </div>
                </div>

                <!-- Payment Summary -->
                <div class="shop-card border-0 shadow-sm p-4">
                    <h6 class="fw-bold text-uppercase small text-muted mb-4">Chi tiết thanh toán</h6>
                    <div class="d-flex flex-column gap-3 mb-4">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Tổng giá trị sản phẩm</span>
                            <span class="fw-bold">@total.ToString("N0") đ</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="text-success fw-bold">Miễn phí</span>
                        </div>
                    </div>
                    <hr class="my-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold h5 mb-0">Tổng cộng:</span>
                        <div class="text-primary h3 fw-black mb-0">@total.ToString("N0") đ</div>
                    </div>
                    
                    @if (Model.Status == SV22T1020073.Models.Sales.OrderStatusEnum.New)
                    {
                        <form id="formCancelOrder" action="/Order/Cancel/@Model.OrderID" method="post">
                            <button type="button" onclick="cancelOrderConfirm()" class="btn btn-outline-danger w-100 rounded-pill py-2 fw-bold">
                                <i class="fas fa-times-circle me-2"></i> Hủy đơn hàng này
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .shop-timeline-premium {
        display: flex;
        justify-content: space-between;
        min-width: 600px;
        position: relative;
        padding: 20px 0;
    }
    .timeline-item {
        flex: 1;
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        z-index: 1;
    }
    .timeline-connector {
        position: absolute;
        top: 24px;
        left: 50%;
        width: 100%;
        height: 3px;
        background: #e2e8f0;
        z-index: -1;
    }
    .timeline-item:last-child .timeline-connector { display: none; }
    
    .timeline-icon-box {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: white;
        border: 2px solid #e2e8f0;
        color: #94a3b8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        transition: all 0.3s;
    }
    .timeline-item.completed .timeline-icon-box {
        background: var(--shop-primary);
        border-color: var(--shop-primary);
        color: white;
    }
    .timeline-item.completed .timeline-connector { background: var(--shop-primary); }
    .timeline-item.active .timeline-icon-box {
        border-color: var(--shop-primary);
        color: var(--shop-primary);
        box-shadow: 0 0 0 4px var(--shop-primary-glare);
    }
    
    .timeline-content {
        text-align: center;
        margin-top: 15px;
    }
    .timeline-title { font-size: 0.875rem; margin-bottom: 2px; }
    .timeline-time { font-size: 0.7rem; }
    .fw-black { font-weight: 900; }
</style>

@section Scripts {
    <script>
        function cancelOrderConfirm() {
            showConfirmModal({
                title: 'Hủy đơn hàng',
                message: 'Bạn có chắc muốn hủy đơn hàng này? Hành động này không thể hoàn tác.',
                confirmText: 'Hủy đơn',
                cancelText: 'Giữ đơn'
            }).then(function (ok) {
                if (ok) document.getElementById('formCancelOrder').submit();
            });
        }
    </script>
}