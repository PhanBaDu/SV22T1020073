@using System.Linq
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
    var loginFlashSuccess = TempData["SuccessMessage"] as string;
    string? loginFlashError = null;
    if (ViewData.ModelState.ErrorCount > 0)
        loginFlashError = string.Join(" ", ViewData.ModelState.Values.SelectMany(v => v.Errors).Select(e => e.ErrorMessage).Where(m => !string.IsNullOrWhiteSpace(m)));
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SHOP</title>
    <link href="https://cdn.jsdelivr.net/npm/mdb-ui-kit@7.3.2/css/mdb.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link href="~/css/shop-theme.css" rel="stylesheet" asp-append-version="true" />
    <style>
        :root {
            --login-bg: #0F172A;
            --login-accent: #38BDF8;
            --login-accent2: #818CF8;
            --login-card-bg: rgba(255,255,255,0.05);
            --login-border: rgba(255,255,255,0.08);
            --login-text: #F1F5F9;
            --login-muted: #94A3B8;
            --login-danger: #F87171;
            --login-radius: 20px;
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--login-bg);
            min-height: 100vh;
            display: flex;
            align-items: stretch;
            padding: 0;
            margin: 0;
        }

        /* Left Panel */
        .login-panel-left {
            flex: 1.1;
            background: linear-gradient(160deg, #1E293B 0%, #0F172A 60%, #1a1040 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 48px;
            position: relative;
            overflow: hidden;
        }

        .login-panel-left::before {
            content: '';
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(56,189,248,0.12) 0%, transparent 70%);
            top: -100px;
            right: -100px;
        }

        .login-panel-left::after {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(129,140,248,0.10) 0%, transparent 70%);
            bottom: -80px;
            left: -80px;
        }

        .login-brand {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            margin-bottom: 64px;
            position: relative;
            z-index: 1;
        }

        .login-brand-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, var(--login-accent), var(--login-accent2));
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.5rem;
            box-shadow: 0 8px 32px rgba(56,189,248,0.3);
        }

        .login-brand-text {
            font-size: 1.75rem;
            font-weight: 800;
            color: white;
            letter-spacing: -0.5px;
        }

        .login-slogan {
            text-align: center;
            position: relative;
            z-index: 1;
        }

        .login-slogan h2 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 16px;
        }

        .login-slogan h2 span {
            background: linear-gradient(90deg, var(--login-accent), var(--login-accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .login-slogan p {
            color: var(--login-muted);
            font-size: 1rem;
            max-width: 340px;
            line-height: 1.7;
        }

        .login-features {
            display: flex;
            flex-direction: column;
            gap: 20px;
            margin-top: 48px;
            width: 100%;
            max-width: 360px;
            position: relative;
            z-index: 1;
        }

        .login-feature-item {
            display: flex;
            align-items: center;
            gap: 16px;
            color: var(--login-text);
            font-size: 0.9375rem;
        }

        .login-feature-item .feature-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .feature-icon.blue { background: rgba(56,189,248,0.15); color: var(--login-accent); }
        .feature-icon.purple { background: rgba(129,140,248,0.15); color: var(--login-accent2); }
        .feature-icon.green { background: rgba(52,211,153,0.15); color: #34D399; }

        /* Right Panel */
        .login-panel-right {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 48px;
            background: white;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 420px;
        }

        .login-form-title {
            font-size: 1.75rem;
            font-weight: 800;
            color: #0F172A;
            margin-bottom: 8px;
            letter-spacing: -0.3px;
        }

        .login-form-subtitle {
            color: #64748B;
            font-size: 0.9375rem;
            margin-bottom: 36px;
        }

        .login-field-group {
            margin-bottom: 20px;
        }

        .login-label {
            display: block;
            font-size: 0.875rem;
            font-weight: 600;
            color: #334155;
            margin-bottom: 8px;
        }

        .login-label span {
            color: #F87171;
        }

        .login-input-wrap {
            position: relative;
        }

        .login-input-wrap .login-input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94A3B8;
            font-size: 0.9375rem;
            transition: color 0.2s;
        }

        .login-input {
            width: 100%;
            padding: 14px 18px 14px 48px;
            border: 2px solid #E2E8F0;
            border-radius: 12px;
            font-size: 0.9375rem;
            font-family: 'Inter', sans-serif;
            color: #0F172A;
            background: #F8FAFC;
            transition: all 0.25s;
        }

        .login-input:focus {
            outline: none;
            border-color: var(--login-accent);
            background: white;
            box-shadow: 0 0 0 4px rgba(56,189,248,0.12);
        }

        .login-input:focus ~ .login-input-icon,
        .login-input-wrap:focus-within .login-input-icon {
            color: var(--login-accent);
        }

        .login-input.is-error {
            border-color: var(--login-danger);
        }

        .login-error-msg {
            font-size: 0.75rem;
            color: var(--login-danger);
            font-weight: 500;
            margin-top: 6px;
            min-height: 16px;
        }

        .login-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--login-accent), var(--login-accent2));
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.25s;
            box-shadow: 0 4px 20px rgba(56,189,248,0.35);
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(56,189,248,0.45);
        }

        .login-btn:active {
            transform: translateY(0);
        }

        .login-divider {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 28px 0;
            color: #94A3B8;
            font-size: 0.8125rem;
        }

        .login-divider::before,
        .login-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #E2E8F0;
        }

        .login-social-btns {
            display: flex;
            gap: 12px;
        }

        .login-social-btn {
            flex: 1;
            padding: 12px;
            border: 2px solid #E2E8F0;
            border-radius: 12px;
            background: white;
            font-size: 1.125rem;
            color: #334155;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            font-size: 0.875rem;
            transition: all 0.2s;
            text-decoration: none;
        }

        .login-social-btn:hover {
            border-color: #CBD5E1;
            background: #F8FAFC;
            transform: translateY(-1px);
        }

        .login-register-cta {
            text-align: center;
            margin-top: 32px;
            color: #64748B;
            font-size: 0.9375rem;
        }

        .login-register-cta a {
            color: var(--login-accent2);
            font-weight: 700;
            text-decoration: none;
        }

        .login-register-cta a:hover {
            text-decoration: underline;
        }

        .login-back-home {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--login-muted);
            text-decoration: none;
            font-size: 0.875rem;
            margin-bottom: 32px;
            transition: color 0.2s;
        }

        .login-back-home:hover {
            color: white;
        }

        /* Responsive */
        @@media (max-width: 900px) {
            body { flex-direction: column; }
            .login-panel-left { padding: 48px 32px; flex: none; }
            .login-features { display: none; }
            .login-panel-right { padding: 48px 24px; }
        }

        @@media (max-width: 480px) {
            .login-panel-left { padding: 40px 20px; }
            .login-panel-right { padding: 32px 16px; }
            .login-slogan h2 { font-size: 1.5rem; }
        }
    </style>
</head>
<body>
    @if (loginFlashSuccess != null || loginFlashError != null)
    {
        <script type="application/json" id="shop-flash-json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { success = loginFlashSuccess, error = loginFlashError }))</script>
    }

    <!-- Left: Branding Panel -->
    <div class="login-panel-left">
        <a href="/" class="login-brand">
            <div class="login-brand-icon">
                <i class="fas fa-bag-shopping"></i>
            </div>
            <span class="login-brand-text">SHOP</span>
        </a>

        <div class="login-slogan">
            <h2>Mua sắm thông minh,<br><span>sống hiện đại</span></h2>
            <p>Khám phá hàng ngàn sản phẩm chất lượng với giá tốt nhất. Đặt hàng dễ dàng, giao hàng nhanh chóng.</p>
        </div>

        <div class="login-features">
            <div class="login-feature-item">
                <div class="feature-icon blue"><i class="fas fa-truck"></i></div>
                <span>Miễn phí vận chuyển cho đơn từ 500K</span>
            </div>
            <div class="login-feature-item">
                <div class="feature-icon purple"><i class="fas fa-shield-alt"></i></div>
                <span>Thanh toán an toàn, 100% khi nhận hàng</span>
            </div>
            <div class="login-feature-item">
                <div class="feature-icon green"><i class="fas fa-undo"></i></div>
                <span>Đổi trả dễ dàng trong 7 ngày</span>
            </div>
        </div>
    </div>

    <!-- Right: Form Panel -->
    <div class="login-panel-right">
        <div class="login-form-wrap">
            <a href="/" class="login-back-home">
                <i class="fas fa-arrow-left"></i> Quay về trang chủ
            </a>

            <h1 class="login-form-title">Chào mừng trở lại</h1>
            <p class="login-form-subtitle">Đăng nhập để tiếp tục mua sắm</p>

            <form id="loginForm" action="~/Account/Login" method="post" novalidate>
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="login-field-group">
                    <label class="login-label">Email <span>*</span></label>
                    <div class="login-input-wrap">
                        <input type="email" id="emailField" name="email"
                               placeholder="example@email.com" autofocus
                               value="@ViewData["Email"]"
                               class="login-input" />
                        <i class="login-input-icon fas fa-envelope"></i>
                    </div>
                    <div class="login-error-msg" id="error-email"></div>
                </div>

                <div class="login-field-group">
                    <label class="login-label">Mật khẩu <span>*</span></label>
                    <div class="login-input-wrap">
                        <input type="password" id="passwordField" name="password"
                               placeholder="Nhập mật khẩu"
                               class="login-input" />
                        <i class="login-input-icon fas fa-lock"></i>
                    </div>
                    <div class="login-error-msg" id="error-password"></div>
                </div>

                <button type="submit" class="login-btn">
                    <i class="fas fa-arrow-right me-2"></i>Đăng nhập
                </button>
            </form>

            <div class="login-divider">hoặc</div>

            <div class="login-social-btns">
                <a href="#" class="login-social-btn">
                    <i class="fab fa-google" style="color:#EA4335;"></i>
                    Google
                </a>
                <a href="#" class="login-social-btn">
                    <i class="fab fa-facebook-f" style="color:#1877F2;"></i>
                    Facebook
                </a>
            </div>

            <div class="login-register-cta">
                Chưa có tài khoản?
                <a href="~/Account/Register?returnUrl=@returnUrl">Tạo tài khoản mới</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/shop-toast.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof showShopFlashFromDom === 'function') showShopFlashFromDom();
        });
        document.getElementById('loginForm').addEventListener('submit', function (e) {
            let hasError = false;
            const showError = (id, msg) => {
                const errSpan = document.getElementById('error-' + id);
                const input = document.getElementById(id + 'Field');
                if (errSpan) errSpan.textContent = msg;
                if (input) input.classList.add('is-error');
                hasError = true;
            };
            const clearError = (id) => {
                const errSpan = document.getElementById('error-' + id);
                const input = document.getElementById(id + 'Field');
                if (errSpan) errSpan.textContent = '';
                if (input) input.classList.remove('is-error');
            };

            ['email', 'password'].forEach(clearError);

            const email = document.getElementById('emailField').value.trim();
            const pass = document.getElementById('passwordField').value;

            if (!email) showError('email', 'Vui lòng nhập Email.');
            else if (!email.includes('@@') || !email.includes('.')) showError('email', 'Email không hợp lệ.');

            if (!pass) showError('password', 'Vui lòng nhập mật khẩu.');

            if (hasError) e.preventDefault();
        });
    </script>
</body>
</html>
