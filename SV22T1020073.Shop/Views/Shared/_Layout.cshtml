<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SHOP</title>
    
    <!-- MDBootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/mdb-ui-kit@7.3.2/css/mdb.min.css" rel="stylesheet" />
    <!-- Bootstrap 5 (required by MDB) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    
    <!-- Custom CSS -->
    <link href="~/css/material-dashboard.css" rel="stylesheet" />
    <link href="~/css/shop-theme.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Top Bar -->
    <div class="shop-topbar">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-white-50 small">
                    <i class="fas fa-truck me-1"></i> Miễn phí vận chuyển cho đơn từ 500K
                </span>
                <div class="d-flex gap-3">
                    <a href="#" class="text-white-50 small text-decoration-none"><i class="fas fa-headset me-1"></i> Hỗ trợ 24/7</a>
                    <a href="#" class="text-white-50 small text-decoration-none"><i class="fas fa-question-circle me-1"></i> Trợ giúp</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="shop-navbar">
        <div class="container-fluid px-4">
            <div class="d-flex align-items-center justify-content-between w-100">
                
                <!-- Logo -->
                <a href="/" class="shop-logo">
                    <span class="shop-logo-icon">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    </span>
                    <span class="shop-logo-text" style="font-family: 'Inter', sans-serif; font-weight: 900; letter-spacing: -0.05em;">
                        MODERN<span style="color: var(--shop-primary);">SHOP</span>
                    </span>
                </a>

                <!-- Center Search -->
                <div class="shop-search d-none d-lg-flex">
                    <form action="/Product" method="get" class="w-100">
                        <div class="shop-search-box">
                            <i class="fas fa-search shop-search-icon"></i>
                            <input type="search" name="SearchValue" placeholder="Tìm kiếm sản phẩm..." 
                                   value="@Context.Request.Query["SearchValue"]" />
                            <button type="submit">Tìm kiếm</button>
                        </div>
                    </form>
                </div>

                <!-- Right Actions -->
                <div class="shop-actions d-flex align-items-center gap-2">
                    <!-- Cart -->
                    <a href="/Cart" class="shop-cart-btn">
                        <i class="fas fa-shopping-cart"></i>
                        <span id="cart-badge" class="shop-cart-badge" style="display: none;">0</span>
                    </a>

                    <!-- User Menu -->
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <button class="shop-user-btn dropdown-toggle border-0 shadow-sm" type="button" 
                                    id="userDropdown" 
                                    data-bs-toggle="dropdown" 
                                    data-bs-display="static"
                                    aria-expanded="false"
                                    style="background: #fff8e1; color: #856404; padding: 6px 20px; border-radius: 50px; font-weight: 600;">
                                <div class="shop-user-avatar d-inline-flex justify-content-center align-items-center bg-warning text-white fw-bold" 
                                     style="width: 32px; height: 32px; border-radius: 50%; font-size: 0.875rem;">
                                    @(User.FindFirst("DisplayName")?.Value?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <span class="d-none d-md-inline ms-2">@(User.FindFirst("DisplayName")?.Value)</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg mt-2 p-2 border-0" aria-labelledby="userDropdown" style="min-width: 250px; border-radius: 16px; background: white !important;">
                                <li class="px-3 py-3 border-bottom mb-2 bg-light rounded-4 mx-2 mt-1">
                                    <span class="d-block small text-muted mb-1">Đang đăng nhập:</span>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 36px; height: 36px;">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <span class="fw-bold text-dark">@(User.FindFirst("DisplayName")?.Value)</span>
                                    </div>
                                </li>
                                <li><a class="dropdown-item py-2 px-3" href="/Account/Profile"><i class="fas fa-user-edit me-3 text-warning"></i>Thông tin cá nhân</a></li>
                                <li><a class="dropdown-item py-2 px-3" href="/Order/History"><i class="fas fa-box-open me-3 text-warning"></i>Đơn hàng của tôi</a></li>
                                <li><hr class="dropdown-divider mx-3" /></li>
                                <li><a class="dropdown-item py-2 px-3 text-danger fw-bold" href="/Account/Logout"><i class="fas fa-sign-out-alt me-3"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="shop-btn-login px-4">Đăng nhập</a>
                        <a href="/Account/Register" class="shop-btn-register px-4 shadow-sm">Đăng ký</a>
                    }
                </div>

                <!-- Mobile Menu Toggle -->
                <button class="shop-mobile-toggle d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu">
                    <i class="fas fa-bars"></i>
                </button>
            </div>

            <!-- Mobile Menu -->
            <div class="collapse" id="mobileMenu">
                <div class="shop-mobile-menu py-3">
                    <form action="/Product" method="get" class="mb-3">
                        <div class="shop-search-box shop-search-mobile">
                            <i class="fas fa-search"></i>
                            <input type="search" name="SearchValue" placeholder="Tìm kiếm..." />
                        </div>
                    </form>
                    <div class="d-flex flex-column gap-2">
                        <a href="/" class="shop-mobile-link @(Context.Request.Path.Value == "/" ? "active" : "")">
                            <i class="fas fa-home me-2"></i>Trang chủ
                        </a>
                        <a href="/Product" class="shop-mobile-link @(Context.Request.Path.Value?.StartsWith("/Product") == true ? "active" : "")">
                            <i class="fas fa-store me-2"></i>Cửa hàng
                        </a>
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <a href="/Order/History" class="shop-mobile-link @(Context.Request.Path.Value?.StartsWith("/Order") == true ? "active" : "")">
                                <i class="fas fa-receipt me-2"></i>Đơn hàng
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    @await Component.InvokeAsync("CategoryNav")

    @{
        var flashSuccess = TempData["SuccessMessage"] as string;
        var flashError = (string?)null;
        if (!Context.Request.Path.StartsWithSegments("/Account/Profile"))
            flashError = TempData["ErrorMessage"] as string;
    }
    @if (flashSuccess != null || flashError != null)
    {
        <script type="application/json" id="shop-flash-json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new { success = flashSuccess, error = flashError }))</script>
    }

    <!-- Main Content -->
    <main class="shop-main">
        <div class="py-4">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="shop-footer">
        <div class="container-fluid px-4">
            <div class="row g-4 py-5">
                <div class="col-lg-4">
                    <div class="shop-logo mb-3">
                        <span class="shop-logo-icon bg-white text-dark shadow-sm">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        </span>
                        <span class="shop-logo-text text-white" style="font-family: 'Inter', sans-serif; font-weight: 900; letter-spacing: -0.05em;">
                            MODERN<span style="color: var(--shop-primary);">SHOP</span>
                        </span>
                    </div>
                    <p class="text-white-50 mt-3 mb-0 lh-lg pe-lg-4">
                        Hệ thống bán hàng trực tuyến hiện đại. Cam kết cung cấp sản phẩm chất lượng cao
                        và dịch vụ chăm sóc tận tâm cho khách hàng trên toàn quốc.
                    </p>
                    <div class="d-flex gap-3 mt-4">
                        <a href="#" class="shop-social-btn"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="shop-social-btn"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="shop-social-btn"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="shop-social-btn"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-bold mb-3">Liên kết</h6>
                    <ul class="list-unstyled mb-0 lh-lg">
                        <li><a href="/Product" class="shop-footer-link">Sản phẩm</a></li>
                        <li><a href="#" class="shop-footer-link">Về chúng tôi</a></li>
                        <li><a href="#" class="shop-footer-link">Liên hệ</a></li>
                        <li><a href="#" class="shop-footer-link">Tin tức</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h6 class="text-white fw-bold mb-3">Hỗ trợ</h6>
                    <ul class="list-unstyled mb-0 lh-lg">
                        <li><a href="#" class="shop-footer-link">Chính sách bảo mật</a></li>
                        <li><a href="#" class="shop-footer-link">Điều khoản dịch vụ</a></li>
                        <li><a href="#" class="shop-footer-link">Hướng dẫn mua hàng</a></li>
                        <li><a href="#" class="shop-footer-link">Chính sách đổi trả</a></li>
                    </ul>
                </div>
                <div class="col-lg-4">
                    <h6 class="text-white fw-bold mb-4">Liên hệ với chúng tôi</h6>
                    <ul class="list-unstyled mb-0 lh-lg text-white-50">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 123 Đường ABC, Quận 1, TP.HCM</li>
                        <li class="mb-2"><i class="fas fa-phone me-2 text-primary"></i> 22T1020073</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i> 22T1020073@@husc.edu.vn</li>
                        <li><i class="fas fa-clock me-2 text-primary"></i> Thứ 2 - Thứ 7: 8:00 - 20:00</li>
                    </ul>
                </div>
            </div>
            <div class="shop-footer-bottom">
                <p class="mb-0 text-center text-white-50 small">
                    &copy; @DateTime.Now.Year SHOP. All rights reserved.
                </p>
            </div>
        </div>
    </footer>

    <!-- Confirm Modal -->
    <div class="modal fade" id="globalConfirmModal" tabindex="-1" aria-labelledby="globalConfirmTitle">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="globalConfirmTitle">Xác nhận</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="globalConfirmMessage" class="mb-0 text-muted"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" id="globalConfirmBtnCancel">Hủy</button>
                    <button type="button" class="btn btn-primary" id="globalConfirmBtnOk">Đồng ý</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Modal -->
    <div class="modal fade" id="globalAlertModal" tabindex="-1" aria-labelledby="globalAlertTitle">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="globalAlertTitle">Thông báo</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p id="globalAlertMessage" class="mb-0"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary w-100" id="globalAlertBtnOk">Đã hiểu</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mdb-ui-kit@7.3.2/js/mdb.umd.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/js/shop-toast.js" asp-append-version="true"></script>

    <script>
        // Cart Badge
        function updateBadge(count) {
            var badge = document.getElementById('cart-badge');
            if (!badge) return;
            count = parseInt(count) || 0;
            
            var auth = @((User?.Identity?.IsAuthenticated == true).ToString().ToLower());
            var userId = "@(User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")";
            
            if (auth && userId) {
                localStorage.setItem('cart_count_' + userId, count);
            } else {
                for (var key in localStorage) {
                    if (key && key.indexOf('cart_count_') === 0) {
                        localStorage.removeItem(key);
                    }
                }
                localStorage.removeItem('cart_count');
            }

            if (count > 0) {
                badge.textContent = count;
                badge.style.display = 'flex';
            } else {
                badge.style.display = 'none';
            }
        }

        function addToCart(id, qty) {
            if (qty === undefined) qty = 1;
            var ret = window.location.pathname + window.location.search;
            fetch('/Cart/Add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'id=' + encodeURIComponent(id) + '&quantity=' + encodeURIComponent(qty) + '&returnUrl=' + encodeURIComponent(ret)
            })
            .then(function(res) { return res.json(); })
            .then(function(data) {
                if (data.success) {
                    updateBadge(data.itemCount);
                    showShopToast(data.message || 'Đã thêm vào giỏ hàng', 'success');
                } else if (data.requireLogin) {
                    window.location.href = data.redirectUrl || '/Account/Login';
                } else {
                    showShopToast(data.message || 'Lỗi khi thêm vào giỏ hàng', 'error');
                }
            })
            .catch(function() {
                showShopToast('Lỗi kết nối server. Vui lòng thử lại.', 'error');
            });
        }

        // Confirm Modal
        function showConfirmModal(options) {
            return new Promise(function (resolve) {
                var modalEl = document.getElementById('globalConfirmModal');
                document.getElementById('globalConfirmTitle').textContent = (options && options.title) ? options.title : 'Xác nhận';
                document.getElementById('globalConfirmMessage').textContent = (options && options.message) ? options.message : '';
                document.getElementById('globalConfirmBtnOk').textContent = (options && options.confirmText) ? options.confirmText : 'Đồng ý';
                document.getElementById('globalConfirmBtnCancel').textContent = (options && options.cancelText) ? options.cancelText : 'Hủy';
                
                var modal = new bootstrap.Modal(modalEl);
                var resolved = false;

                function finish(val) {
                    if (resolved) return;
                    resolved = true;
                    modal.hide();
                    resolve(val);
                }

                document.getElementById('globalConfirmBtnOk').onclick = function() { finish(true); };
                document.getElementById('globalConfirmBtnCancel').onclick = function() { finish(false); };
                modalEl.addEventListener('hidden.bs.modal', function() { if (!resolved) finish(false); });
                modal.show();
            });
        }

        function showAlertModal(message, title) {
            showShopToast(message || '', 'error');
            return Promise.resolve();
        }

        document.addEventListener('DOMContentLoaded', function() {
            if (typeof showShopFlashFromDom === 'function') showShopFlashFromDom();

            var auth = @((User?.Identity?.IsAuthenticated == true).ToString().ToLower());
            var userId = "@(User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "")";

            if (auth && userId) {
                var savedCount = localStorage.getItem('cart_count_' + userId);
                if (savedCount !== null) updateBadge(savedCount);
            }

            fetch('/Cart/GetCartCount')
                .then(function(res) { return res.json(); })
                .then(function(data) { updateBadge(data.count); });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>