@using SV22T1020073.Models.Catalog
@using SV22T1020073.Models.Common
@{
    var productResult = ViewBag.ProductResult as PagedResult<Product>;
    int totalProducts = productResult?.RowCount ?? 0;
}

<!-- Hero Section -->
<section class="shop-hero">
    <div class="container-fluid px-4">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1 class="display-3 fw-bold mb-4" style="color: #ffffff !important; letter-spacing: -0.02em; line-height: 1.1;">
                    Mua sắm thông minh,<br>
                    <span style="color: var(--shop-primary) !important; font-family: 'Inter', sans-serif;">sống hiện đại</span>
                </h1>
                <p class="mb-5 lead" style="color: rgba(255,255,255,0.9) !important; font-weight: 400; max-width: 600px;">
                    Khám phá hàng ngàn sản phẩm chất lượng với giá tốt nhất. 
                    <span class="d-block mt-2" style="color: var(--shop-primary); font-weight: 600;">Giao hàng nhanh chóng trong 24h.</span>
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a href="/Product" class="shop-btn-primary shop-btn-lg px-5 py-3 rounded-pill">
                        <i class="fas fa-shopping-bag me-2"></i>Mua sắm ngay
                    </a>
                    <a href="/Product?CategoryID=1" class="shop-btn-outline shop-btn-lg px-5 py-3 rounded-pill text-white border-white">
                        <i class="fas fa-th-large me-2"></i>Xem danh mục
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<div class="container-fluid px-4">
    <div class="row g-4">
        <!-- Sidebar Filter -->
        <div class="col-lg-3">
            @await Html.PartialAsync("_CardFilter", ViewBag.FilterInput as ProductSearchInput)
        </div>

        <!-- Product List -->
        <div class="col-lg-9">
            <!-- Search Status -->
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                <div>
                    <span class="text-muted small" id="searchStatusText">Kết quả tìm kiếm</span>
                    <span class="mx-2 text-black-50">|</span>
                    <strong id="productCountDisplayStatus" style="color: var(--shop-primary);">@totalProducts.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))</strong>
                    <span class="text-muted small">sản phẩm</span>
                </div>
                <div class="text-muted small">
                    Hiển thị <strong>@productResult?.DataItems?.Count()</strong> / trang
                </div>
            </div>

            <!-- Results -->
            <div id="searchResult">
                @await Html.PartialAsync("_ProductGrid", productResult ?? new PagedResult<Product>())
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>


        function syncProductCountFromResult() {
            var $meta = $("#searchResult .js-paged-meta");
            if (!$meta.length) return;
            var n = parseInt($meta.attr("data-row-count"), 10);
            if (isNaN(n)) n = 0;
            $("#productCountDisplayStatus").text(n.toLocaleString("vi-VN"));
            
            var catName = $("#searchCategoryID option:selected").text().trim();
            var catVal = $("#searchCategoryID").val();
            var searchVal = $("#searchValueState").val() || "";

            var combined = "";
            var searchPart = searchVal ? `từ khóa "${searchVal}"` : "";
            var categoryPart = (catVal && catVal !== "0") ? `trong danh mục "${catName}"` : "";

            if (searchPart && categoryPart) combined = `${searchPart} ${categoryPart}`;
            else if (searchPart) combined = searchPart;
            else if (categoryPart) combined = categoryPart;

            var finalMsg = combined ? `Kết quả ${combined}` : "Tất cả sản phẩm";
            $("#searchStatusText").text(finalMsg);
            
            $meta.remove();
        }

        function applyPricePreset() {
            var val = $("#pricePreset").val();
            if (!val) {
                $("#minPriceInput").val("");
                $("#maxPriceInput").val("");
                return;
            }
            var parts = val.split(",");
            $("#minPriceInput").val(parts[0] || "");
            $("#maxPriceInput").val(parts[1] || "");
        }

        function doSearch(page) {
            applyPricePreset();
            $("#formSearch input[name='Page']").val(page);
            var params = {
                CategoryID: $("#searchCategoryID").val(),
                MinPrice: $("#minPriceInput").val(),
                MaxPrice: $("#maxPriceInput").val(),
                Page: page,
                SearchValue: $("#searchValueState").val() || ""
            };

            $.ajax({
                url: "/Home/Search",
                type: "GET",
                data: params,
                success: function (data) {
                    $("#searchResult").html(data);
                    syncProductCountFromResult();
                },
                error: function () {
                    $("#searchResult").html('<div class="shop-empty"><div class="shop-empty-icon"><i class="fas fa-exclamation-triangle"></i></div><h3>Có lỗi xảy ra</h3><p>Vui lòng thử lại.</p></div>');
                }
            });
        }

        function resetFilter() {
            $("select[name='CategoryID']").val("0");
            $("#pricePreset").val("");
            $("#minPriceInput").val("");
            $("#maxPriceInput").val("");
            $("#searchValueState").val("");
            doSearch(1);
        }

        $(document).ready(function () {
            selectPricePresetFromInputs();
            syncProductCountFromResult();

            $("#minPriceInput, #maxPriceInput").on("input", function () {
                $("#pricePreset").val("");
            });
        });

        function selectPricePresetFromInputs() {
            var min = parseInt($("#minPriceInput").val()) || 0;
            var max = parseInt($("#maxPriceInput").val()) || 0;
            if (min === 0 && max === 0) return;
            $("#pricePreset option").each(function () {
                var val = $(this).val();
                if (!val) return;
                var parts = val.split(",");
                var pMin = parseInt(parts[0]) || 0;
                var pMax = parseInt(parts[1]) || 0;
                if (pMin === min && pMax === max) {
                    $("#pricePreset").val(val);
                }
            });
        }
    </script>
}