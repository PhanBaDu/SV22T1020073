@using SV22T1020073.Models.HR
@model Employee
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Thông tin hồ sơ</h3>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible">
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Profile" method="post" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="fullName" class="form-label">Họ tên:</label>
                        <input type="text" class="form-control" id="fullName" name="fullName"
                               value="@Model.FullName" required maxlength="255"
                               oninvalid="this.setCustomValidity('Vui lòng nhập họ tên')"
                               oninput="this.setCustomValidity('')" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email:</label>
                        <input type="email" class="form-control" id="email" name="email"
                               value="@Model.Email" required maxlength="255"
                               oninvalid="this.setCustomValidity('Vui lòng nhập địa chỉ email hợp lệ')"
                               oninput="this.setCustomValidity('')" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="phone" class="form-label">Điện thoại:</label>
                        <input type="tel" class="form-control" id="phone" name="phone" value="@Model.Phone" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="birthDate" class="form-label">Ngày sinh:</label>
                        <input type="date" class="form-control" id="birthDate" name="birthDate"
                               value="@(Model.BirthDate?.ToString("yyyy-MM-dd"))"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        @Html.ValidationMessage("birthDate", "", new { @class = "text-danger d-block small" })
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="address" class="form-label">Địa chỉ:</label>
                <input type="text" class="form-control" id="address" name="address" value="@Model.Address" />
            </div>
            <div class="mb-3">
                <label for="uploadPhoto" class="form-label">Ảnh đại diện:</label>
                @if (!string.IsNullOrEmpty(Model.Photo))
                {
                    <div class="mb-2">
                        <img src="~/images/employees/@Model.Photo" alt="Avatar" class="img-thumbnail" style="max-width: 150px;" />
                    </div>
                }
                <input type="file" class="form-control" id="uploadPhoto" name="uploadPhoto" accept="image/*" />
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu thay đổi
            </button>
            <a asp-action="ChangePassword" class="btn btn-warning ms-2">
                <i class="bi bi-key"></i> Đổi mật khẩu
            </a>
        </form>
    </div>
</div>
