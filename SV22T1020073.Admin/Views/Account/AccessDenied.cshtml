@{
    ViewBag.Title = "Từ chối truy cập";
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <title>Từ chối truy cập - TNP Shop</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/adminlte/css/adminlte.css" />
</head>
<body class="bg-body-secondary">
    <div class="error-page">
        <div class="error-content" style="margin-left: auto; margin-right: auto; max-width: 500px; padding-top: 50px; text-align: center;">
            <div class="card">
                <div class="card-body">
                    <div class="error-page" style="padding: 50px 0;">
                        <h1 class="headline text-danger" style="font-size: 100px; font-weight: 700;">403</h1>
                        <h3 class="text-danger">
                            <i class="bi bi-shield-lock fs-1"></i>
                            <br />
                            Bạn không có quyền truy cập trang này
                        </h3>
                        <p class="text-muted">
                            Tài khoản của bạn không được cấp quyền để thực hiện thao tác này.
                            <br />
                            Vui lòng liên hệ Quản trị viên nếu bạn cần được cấp quyền.
                        </p>
                        <div class="mt-4">
                            <button type="button" onclick="goBack()" class="btn btn-primary me-2">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </button>
                            <a href="~/Account/Logout" class="btn btn-outline-secondary">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        function goBack() {
            if (window.history.length > 1) {
                window.history.back();
            } else {
                window.location.href = '/';
            }
        }
    </script>
</body>
</html>
