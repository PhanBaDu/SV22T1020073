@model SV22T1020073.Models.Sales.OrderViewInfo
@{
    Layout = null;
}
<div class="modal-header text-bg-success">
    <strong class="modal-title">
        <i class="bi bi-bag-check me-2"></i>Hoàn tất đơn hàng #@Model.OrderID
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="alert alert-success d-flex align-items-center">
        <i class="bi bi-info-circle me-2"></i>
        Bạn có chắc chắn xác nhận đơn hàng này đã được giao thành công không?
    </div>

    <dl class="row mb-0">
        <dt class="col-sm-4 text-muted">Khách hàng</dt>
        <dd class="col-sm-8">@Model.CustomerName</dd>

        <dt class="col-sm-4 text-muted">Người giao hàng</dt>
        <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.ShipperName) ? "—" : Model.ShipperName)</dd>

        <dt class="col-sm-4 text-muted">Tổng tiền</dt>
        <dd class="col-sm-8 fw-bold text-danger">@Model.TotalAmount.ToString("N0") ₫</dd>

        <dt class="col-sm-4 text-muted">Địa chỉ giao</dt>
        <dd class="col-sm-8">@Model.DeliveryAddress, @Model.DeliveryProvince</dd>
    </dl>
</div>

<div class="modal-footer">
    <form method="post" action="~/Order/Finish/@Model.OrderID" class="d-inline">
        <input type="hidden" name="confirm" value="yes" />
        <button type="submit" class="btn btn-success me-2">
            <i class="bi bi-check-circle me-1"></i> Hoàn tất đơn hàng
        </button>
    </form>
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
</div>
