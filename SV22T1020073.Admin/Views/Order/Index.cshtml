@using SV22T1020073.Admin
@using SV22T1020073.Models.Constants
@using SV22T1020073.Models.Sales
@model SV22T1020073.Models.Sales.OrderSearchInput
@{
    ViewBag.Title = "Quản lý Đơn hàng";
}
@section PageToolBar {
    @if (ApplicationContext.HasPermission(Permissions.OrderCreate))
    {
        <a href="~/Order/Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>
            Lập đơn hàng mới
        </a>
    }
}
<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Order/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Trạng thái đơn hàng</label>
                    <select name="status" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="1" selected="@(Model.Status == OrderStatusEnum.New)">Đang chờ duyệt</option>
                        <option value="2" selected="@(Model.Status == OrderStatusEnum.Accepted)">Đã duyệt</option>
                        <option value="3" selected="@(Model.Status == OrderStatusEnum.Shipping)">Đang giao</option>
                        <option value="4" selected="@(Model.Status == OrderStatusEnum.Completed)">Hoàn tất</option>
                        <option value="-1" selected="@(Model.Status == OrderStatusEnum.Cancelled)">Bị hủy</option>
                        <option value="-2" selected="@(Model.Status == OrderStatusEnum.Rejected)">Bị từ chối</option>
                    </select>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Thời gian lập đơn hàng</label>
                    <div class="input-group">
                        <input type="text" name="dateFrom" class="form-control date-picker" placeholder="Từ ngày..." value="@(Model.DateFrom?.ToString("dd/MM/yyyy"))" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="dateTo" class="form-control date-picker" placeholder="...đến ngày" value="@(Model.DateTo?.ToString("dd/MM/yyyy"))" />
                    </div>
                </div>

                <div class="col-md-5">
                    <label class="form-label">Tên khách hàng</label>
                    <div class="input-group">
                        <input type="text"
                               name="searchValue"
                               class="form-control"
                               placeholder="Tên khách hàng..."
                               autofocus
                               value="@Model.SearchValue" />

                        <button class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}
