@model Employee
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">                
                <!-- Đối với form có upload file, phải có enctype="multipart/form-data" -->
                <form id="formEdit" method="post" enctype="multipart/form-data" action="~/Employee/SaveData">
                    
                    <input type="hidden" asp-for="EmployeeID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên <span class="text-danger">*</span></label>
                        <div class="col-sm-5">
                            <input type="text" asp-for="FullName"
                                   class="form-control"
                                   placeholder="Nhập họ và tên nhân viên"
                                   required maxlength="255" autofocus
                                   oninvalid="this.setCustomValidity('Vui lòng nhập họ và tên nhân viên')"
                                   oninput="this.setCustomValidity('')" />
                            <span class="text-danger" asp-validation-for="FullName"></span>
                        </div>
                        <label class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input type="text" asp-for="BirthDate"
                                   class="form-control date-picker-birth"
                                   placeholder="dd/mm/yyyy"
                                   autocomplete="bday" />
                            <span class="text-danger d-block small" asp-validation-for="BirthDate"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" asp-for="Address"
                                      rows="3"
                                      placeholder="Nhập địa chỉ"
                                      maxlength="255"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-2">
                            <input type="tel" asp-for="Phone"
                                   class="form-control"
                                   placeholder="Ví dụ: 0901234567 hoặc 028.3822.1111"
                                   required maxlength="20"
                                   oninvalid="this.setCustomValidity('Vui lòng nhập số điện thoại')"
                                   oninput="this.setCustomValidity('')" />
                        </div>
                        <label class="col-sm-1 col-form-label text-end">Email <span class="text-danger">*</span></label>
                        <div class="col-sm-6">
                            <input type="email" asp-for="Email"
                                   class="form-control"
                                   placeholder="Nhập email nhân viên"
                                   required maxlength="255"
                                   oninvalid="this.setCustomValidity('Vui lòng nhập email nhân viên')"
                                   oninput="this.setCustomValidity('')" />
                            <span class="text-danger" asp-validation-for="Email"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <!-- Sử dụng hidden input để lưu giữ tên file ảnh hiện tại của nhân viên-->
                            <input type="hidden" asp-for="Photo" />
                            <!-- Sử dụng input có name="uploadPhoto" để upload ảnh (tránh không sử dụng name="Photo") -->
                            <input type="file" name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   data-img-preview="imgPreview"
                                   onchange="previewImage(this)" />
                            <div class="form-text">Ảnh là tùy chọn; nếu không chọn, hệ thống dùng ảnh mặc định.</div>
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail"
                                     style="max-height: 150px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" asp-for="IsWorking"
                                       type="checkbox"
                                       id="IsWorking" />
                                <label class="form-check-label" for="IsWorking">
                                    Đang làm việc
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-9 offset-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('formEdit');
            if (!form) return;

            form.addEventListener('submit', function (e) {
                const birth = form.querySelector('input[name="BirthDate"]');
                if (birth && birth._flatpickr && birth._flatpickr.selectedDates.length) {
                    const d = birth._flatpickr.selectedDates[0];
                    const dDate = new Date(d.getFullYear(), d.getMonth(), d.getDate());
                    const now = new Date();
                    const todayDate = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                    if (dDate > todayDate) {
                        e.preventDefault();
                        birth.setCustomValidity('Ngày sinh không được là ngày trong tương lai');
                        birth.reportValidity();
                        return;
                    }
                    birth.setCustomValidity('');
                }

                const phone = form.querySelector('input[name="Phone"]');
                if (!phone) return;
                const v = phone.value.trim();
                if (!v) {
                    e.preventDefault();
                    phone.setCustomValidity('Vui lòng nhập số điện thoại');
                    phone.reportValidity();
                    return;
                }
                
                // Regex: allows digits, whitespace, dot, plus, minus, parenthesis
                // We use \s for all space-like characters and move - to the end
                if (!/^[0-9\s.+\-()]+$/.test(v)) {
                    e.preventDefault();
                    phone.setCustomValidity('Số điện thoại chỉ được chứa chữ số và khoảng trắng, dấu chấm, gạch ngang, ngoặc');
                    phone.reportValidity();
                    return;
                }
                const digits = (v.replace(/\D/g, '')).length;
                if (digits < 8 || digits > 15) {
                    e.preventDefault();
                    phone.setCustomValidity('Số điện thoại cần từ 8 đến 15 chữ số');
                    phone.reportValidity();
                    return;
                }
                phone.setCustomValidity('');
            });

            $('input, textarea, select').on('input change', function () {
                const fieldName = $(this).attr('name');
                if (fieldName) {
                    $(`span[data-valmsg-for="${fieldName}"]`).text('');
                    $(this).siblings('.text-danger').text('');
                }
                if ($(this).attr('name') === 'Phone') this.setCustomValidity('');
                if ($(this).attr('name') === 'BirthDate') this.setCustomValidity('');
            });
        })();
    </script>
}
