@using SV22T1020073.Admin
@using SV22T1020073.Models.Constants
@model SV22T1020073.Models.Common.PagedResult<SV22T1020073.Models.HR.Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên. Trang <strong>@Model.Page/@Model.PageCount</strong>
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th style="width:100px;">Ảnh</th>
                    <th>Họ và tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center" style="width:120px;">Trạng thái</th>
                    <th class="text-center" style="min-width: 11rem;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/employees/nophoto.png" : "/images/employees/" + item.Photo)"
                                 class="rounded" style="width: 50px; height: 50px; object-fit: cover;" alt="@item.FullName" />
                        </td>
                        <td>@item.FullName</td>
                        <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td class="text-center">
                            @if (item.IsWorking == true)
                            {
                                <span class="badge bg-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã nghỉ việc</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="d-inline-flex flex-wrap gap-1 justify-content-center align-items-center employee-action-btns">
                                @* Thứ tự: Sửa → Xóa → Đổi mật khẩu → Phân quyền (theo mock ui/) *@
                                @if (ApplicationContext.HasPermission(Permissions.EmployeeEdit))
                                {
                                    <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-primary rounded-3 d-inline-flex align-items-center justify-content-center p-0 employee-action-btn" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                @if (ApplicationContext.HasPermission(Permissions.EmployeeDelete))
                                {
                                    <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-danger rounded-3 d-inline-flex align-items-center justify-content-center p-0 employee-action-btn" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                                @if (ApplicationContext.HasPermission(Permissions.EmployeeChangePassword))
                                {
                                    <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-warning rounded-3 d-inline-flex align-items-center justify-content-center p-0 employee-action-btn" title="Đổi mật khẩu">
                                        <i class="bi bi-key"></i>
                                    </a>
                                }
                                @if (ApplicationContext.HasPermission(Permissions.EmployeeAssignRole))
                                {
                                    <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-info rounded-3 d-inline-flex align-items-center justify-content-center p-0 employee-action-btn" title="Phân quyền">
                                        <i class="bi bi-shield-check"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination justify-content-center">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.Page == 0)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else if (p.IsCurrent)
                    {
                        <li class="page-item active"><span class="page-link">@p.Page</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;" onclick="doSearch(@p.Page)">@p.Page</a>
                        </li>
                    }
                }
            </ul>
        }
    </div>
</div>
