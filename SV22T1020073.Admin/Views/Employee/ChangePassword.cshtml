@{
    var employee = ViewBag.Employee as SV22T1020073.Models.HR.Employee;
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary">
        <i class="bi bi-key me-1"></i>
        Đổi mật khẩu
    </button>
    <a href="~/Employee" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-warning card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-lock me-2"></i>
                    Đổi mật khẩu nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangePassword" asp-action="ChangePassword" asp-controller="Employee" asp-route-id="@employee!.EmployeeID" method="post">

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3 border-bottom pb-2 w-100">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@employee?.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@employee?.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (employee?.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3 border-bottom pb-2 w-100">
                            <i class="bi bi-key me-1"></i>
                            Thông tin mật khẩu
                        </legend>

                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password"
                                   name="newPassword"
                                   class="form-control"
                                   placeholder="Nhập mật khẩu mới (ít nhất 6 ký tự)" />
                            @Html.ValidationMessage("newPassword", new { @class = "text-danger" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                            <input type="password"
                                   name="confirmPassword"
                                   class="form-control"
                                   placeholder="Nhập lại mật khẩu mới" />
                            @Html.ValidationMessage("confirmPassword", new { @class = "text-danger" })
                        </div>
                    </fieldset>

                    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>
