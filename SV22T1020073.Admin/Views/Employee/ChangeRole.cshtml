@using SV22T1020073.Models.Constants
@{
    var employee = ViewBag.Employee as SV22T1020073.Models.HR.Employee;
    var currentRoles = (employee?.RoleNames ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Select(r => r.Trim())
        .ToList();

    bool HasRole(string role) => currentRoles.Contains(role, StringComparer.OrdinalIgnoreCase);

    var roleRows = new (string RoleKey, string Title, string Description)[]
    {
        (Roles.Sales, "Quản lý khách hàng", "Thêm, sửa, xóa và xem danh sách khách hàng; tạo và xử lý đơn hàng"),
        (Roles.Inventory, "Quản lý mặt hàng", "Quản lý thông tin sản phẩm, giá bán, trạng thái"),

        (Roles.Manager, "Quản lý đơn hàng & nghiệp vụ", "Tạo, xử lý và theo dõi đơn hàng; quản lý nhà cung cấp, shipper và hàng hóa"),
        (Roles.Admin, "Quản trị hệ thống", "Quản lý người dùng, phân quyền, toàn bộ chức năng hệ thống"),
    };

    var knownRoleKeys = new HashSet<string>(roleRows.Select(r => r.RoleKey), StringComparer.OrdinalIgnoreCase);
    var extraRoles = currentRoles
        .Where(r => !string.IsNullOrWhiteSpace(r) && !knownRoleKeys.Contains(r))
        .GroupBy(r => r, StringComparer.OrdinalIgnoreCase)
        .Select(g => g.First())
        .ToList();

    var currentUserId = SV22T1020073.Admin.ApplicationContext.CurrentUser?.EmployeeID ?? 0;
    bool isSelfEdit = employee?.EmployeeID == currentUserId;
}
@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" asp-action="ChangeRole" asp-controller="Employee" asp-route-id="@employee!.EmployeeID" method="post">

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3 border-bottom pb-2 w-100">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@(employee?.FullName ?? "—")</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@(employee?.Email ?? "—")</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (employee?.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3 border-bottom pb-2 w-100">
                            <i class="bi bi-shield-lock me-1"></i>
                            Danh sách quyền
                        </legend>

                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle mb-0">
                                <thead class="table-secondary">
                                    <tr>
                                        <th style="width:70px;" class="text-center">Chọn</th>
                                        <th>Tên quyền</th>
                                        <th>Mô tả quyền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in roleRows)
                                    {
                                        <tr>
                                            <td class="text-center">
                                                @{
                                                    bool isDisabled = isSelfEdit && row.RoleKey == Roles.Admin;
                                                }
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="roles"
                                                       value="@row.RoleKey"
                                                       id="role_@row.RoleKey"
                                                       @(HasRole(row.RoleKey) ? "checked" : "")
                                                       @(isDisabled ? "disabled" : "") />

                                                @if (isDisabled && HasRole(row.RoleKey))
                                                {
                                                    <input type="hidden" name="roles" value="@row.RoleKey" />
                                                }
                                            </td>
                                            <td class="fw-semibold">
                                                <label class="form-check-label mb-0" for="role_@row.RoleKey">@row.Title</label>
                                            </td>
                                            <td class="text-muted">@row.Description</td>
                                        </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </fieldset>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mt-3 mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
                        </div>
                    }
                </form>
            </div>
        </div>
    </div>
</div>
