@model SV22T1020073.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Xóa thuộc tính";
}
<div class="card">
    <div class="card-header bg-danger">
        <h3 class="card-title text-white">Xác nhận xóa thuộc tính</h3>
    </div>
    <div class="card-body">
        <p class="mb-4">Bạn có chắc chắn muốn xóa thuộc tính <strong class="text-danger">@Model.AttributeName: @Model.AttributeValue</strong>?</p>

        <form asp-action="DeleteAttribute" method="post">
            <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
            <input type="hidden" name="ProductID" value="@Model.ProductID" />
            <div class="mt-4">
                <button type="submit" class="btn btn-danger me-2">
                    <i class="bi bi-trash me-1"></i> Xóa thuộc tính
                </button>
                <a asp-action="Edit" asp-route-id="@Model.ProductID" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại sản phẩm
                </a>
            </div>
        </form>
    </div>
</div>
