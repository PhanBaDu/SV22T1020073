@model SV22T1020073.Models.Catalog.ProductPhoto
@{
    ViewBag.Title = "Xóa ảnh sản phẩm";
}
<div class="card">
    <div class="card-header bg-danger">
        <h3 class="card-title text-white">Xác nhận xóa ảnh</h3>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <img src="~/photos/products/@Model.Photo" class="img-thumbnail" style="max-height: 200px;"
                     onerror="this.src='https://placehold.co/300x200?text=No+Image'">
            </div>
            <div class="col-md-8">
                <p class="mb-3">Bạn có chắc chắn muốn xóa ảnh <strong class="text-danger">@Model.Photo</strong>?</p>

                <dl class="row">
                    <dt class="col-sm-4 text-muted">Mô tả:</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4 text-muted">Thứ tự hiển thị:</dt>
                    <dd class="col-sm-8">@Model.DisplayOrder</dd>

                    <dt class="col-sm-4 text-muted">Trạng thái:</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsHidden)
                        {
                            <span class="badge bg-secondary">Đang ẩn</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Đang hiển thị</span>
                        }
                    </dd>
                </dl>

                <form asp-action="DeletePhoto" method="post">
                    <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <div class="mt-4">
                        <button type="submit" class="btn btn-danger me-2">
                            <i class="bi bi-trash me-1"></i> Xóa ảnh
                        </button>
                        <a asp-action="Edit" asp-route-id="@Model.ProductID" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại sản phẩm
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
