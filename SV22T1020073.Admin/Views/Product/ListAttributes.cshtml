@using System.Linq
@using SV22T1020073.Models.Catalog
@{
    var standalone = ViewData["ProductListAttributesStandalone"] as bool? == true;
    Layout = standalone ? "_Layout" : null;

    int productId = 0;
    var attributeList = new List<ProductAttribute>();

    if (Model is Product prod)
    {
        productId = prod.ProductID;
        if (ViewBag.Attributes is IEnumerable<ProductAttribute> fromBag)
            attributeList = fromBag.ToList();
    }
    else if (Model is IList<ProductAttribute> list)
    {
        attributeList = list.ToList();
        productId = ViewBag.ProductID is int pid ? pid : attributeList.FirstOrDefault()?.ProductID ?? 0;
    }
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        @if (productId > 0)
                        {
                            <a class="btn btn-sm btn-primary" href="~/Product/CreateAttribute/@productId">
                                <i class="bi bi-plus-circle me-1"></i>
                                Thêm thuộc tính
                            </a>
                        }
                        else
                        {
                            <span class="badge bg-info-subtle text-primary border border-info-subtle px-3 py-2">
                                <i class="bi bi-info-circle-fill me-1"></i>
                                Vui lòng thêm mặt hàng trước khi bổ sung thuộc tính
                            </span>
                        }
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary text-center small fw-bold">
                        <tr>
                            <th>Tên thuộc tính</th>
                            <th>Giá trị</th>
                            <th style="width:80px">Thứ tự</th>
                            <th style="width:50px"></th>
                        </tr>
                    </thead>
                    <tbody id="attributeTableBody">
                        @if (productId == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <div class="mb-2"><i class="bi bi-list-check fs-1 opacity-25"></i></div>
                                    <div>Vui lòng <b>Thêm mặt hàng trước</b> để có thể thiết lập các thuộc tính.</div>
                                </td>
                            </tr>
                        }
                        else if (attributeList.Count == 0)
                        {
                            <tr id="noAttrMsg">
                                <td colspan="4" class="text-center text-muted py-4 small">Chưa có thuộc tính nào của mặt hàng này.</td>
                            </tr>
                        }
                        @foreach (var item in attributeList)
                        {
                            <tr>
                                <td class="align-middle">@item.AttributeName</td>
                                <td class="align-middle">@item.AttributeValue</td>
                                <td class="text-center align-middle">@item.DisplayOrder</td>
                                <td class="text-center align-middle text-nowrap">
                                    <a class="btn btn-sm btn-primary" href="~/Product/EditAttribute/@productId?attributeId=@item.AttributeID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-sm btn-danger" href="~/Product/DeleteAttribute/@productId?attributeId=@item.AttributeID">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


