@model SV22T1020073.Models.Catalog.Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}
<div class="card">
    <div class="card-header bg-danger">
        <h3 class="card-title text-white">Xác nhận xóa mặt hàng</h3>
    </div>
    <div class="card-body">
        <p class="mb-4">Bạn có chắc chắn muốn xóa mặt hàng <strong class="text-danger">@Model.ProductName</strong>?</p>

        <dl class="row">
            <dt class="col-sm-3 text-muted">Mã mặt hàng:</dt>
            <dd class="col-sm-9">@Model.ProductID</dd>

            <dt class="col-sm-3 text-muted">Tên mặt hàng:</dt>
            <dd class="col-sm-9">@Model.ProductName</dd>

            <dt class="col-sm-3 text-muted">Loại hàng:</dt>
            <dd class="col-sm-9">@(ViewBag.CategoryName ?? "N/A")</dd>

            <dt class="col-sm-3 text-muted">Nhà cung cấp:</dt>
            <dd class="col-sm-9">@(ViewBag.SupplierName ?? "N/A")</dd>

            <dt class="col-sm-3 text-muted">Đơn vị tính:</dt>
            <dd class="col-sm-9">@Model.Unit</dd>

            <dt class="col-sm-3 text-muted">Giá bán:</dt>
            <dd class="col-sm-9 fw-bold text-danger">@Model.Price.ToString("N0") ₫</dd>

            <dt class="col-sm-3 text-muted">Trạng thái:</dt>
            <dd class="col-sm-9">
                @if (Model.IsSelling)
                {
                    <span class="badge bg-success">Đang bán</span>
                }
                else
                {
                    <span class="badge bg-secondary">Ngừng bán</span>
                }
            </dd>
        </dl>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            </div>
        }

        <form asp-action="Delete" method="post">
            <input type="hidden" name="ProductID" value="@Model.ProductID" />
            <div class="mt-4">
                <button type="submit" class="btn btn-danger me-2">
                    <i class="bi bi-trash me-1"></i> Xóa mặt hàng
                </button>
                <a href="~/Product" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại
                </a>
            </div>
        </form>
    </div>
</div>
