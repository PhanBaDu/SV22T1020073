@model SV22T1020073.Models.Catalog.ProductAttribute
@{
    ViewBag.Title = "Sửa thuộc tính";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu thuộc tính
    </button>

    <a href="~/Product/Edit/@Model.ProductID#attributes" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-success">
            <div class="card-header">
                <h5 class="mb-0">Thông tin thuộc tính mặt hàng</h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post">
                    <input type="hidden" name="AttributeID" value="@Model.AttributeID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Tên thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeName"
                                   class="form-control"
                                   placeholder="Ví dụ: Màu sắc, Kích thước"
                                   value="@Model.AttributeName"
                                   required autofocus
                                   oninvalid="this.setCustomValidity('Vui lòng nhập tên thuộc tính')"
                                   oninput="this.setCustomValidity('')" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Giá trị thuộc tính
                        </label>
                        <div class="col-sm-9">
                            <input type="text"
                                   name="AttributeValue"
                                   class="form-control"
                                   placeholder="Ví dụ: Đỏ, XL, 500g"
                                   value="@Model.AttributeValue"
                                   required
                                   oninvalid="this.setCustomValidity('Vui lòng nhập giá trị thuộc tính')"
                                   oninput="this.setCustomValidity('')" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">
                            Thứ tự hiển thị
                        </label>
                        <div class="col-sm-3">
                            <input type="number"
                                   name="DisplayOrder"
                                   class="form-control"
                                   value="@(Model.DisplayOrder > 0 ? Model.DisplayOrder.ToString() : "1")"
                                   min="1" />
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>