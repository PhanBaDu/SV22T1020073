@using SV22T1020073.Admin
@using SV22T1020073.Models.Constants
@{
    var roleNames = Context.Session.GetString("EmployeeRoles") ?? "";
    var roles = string.IsNullOrWhiteSpace(roleNames)
        ? new List<string>()
        : roleNames.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    var permissions = new List<string>();
    foreach (var role in roles)
    {
        var perms = Roles.GetPermissions(role);
        foreach (var perm in perms)
        {
            if (!permissions.Contains(perm))
                permissions.Add(perm);
        }
    }
    bool HasPerm(string p) => permissions.Contains(p);
}
<aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
    <div class="sidebar-brand">
        <a href="#" class="brand-link">
            <img src="~/lib/adminlte/assets/img/AdminLTELogo.png" alt="Logo" class="brand-image opacity-75 shadow" />
            <span class="brand-text fw-light">TNP Shop</span>
        </a>
    </div>
    <div class="sidebar-wrapper">
        <nav class="mt-2">
            <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation"
                aria-label="Main navigation" data-accordion="false" id="navigation">

                @if (HasPerm(Permissions.DashboardView))
                {
                    <li class="nav-item">
                        <a href="~/" class="nav-link">
                            <i class="nav-icon bi bi-speedometer2"></i>
                            <p>Trang chủ</p>
                        </a>
                    </li>
                }

                @if (HasPerm(Permissions.SupplierView) || HasPerm(Permissions.CustomerView) || HasPerm(Permissions.ShipperView) || HasPerm(Permissions.EmployeeView))
                {
                    <li class="nav-item menu-open">
                        <a href="#" class="nav-link active">
                            <i class="nav-icon bi bi-archive"></i>
                            <p>
                                Quản lý dữ liệu
                                <i class="nav-arrow bi bi-chevron-right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            @if (HasPerm(Permissions.SupplierView))
                            {
                                <li class="nav-item">
                                    <a href="~/Supplier" class="nav-link">
                                        <i class="nav-icon bi bi-truck"></i>
                                        <p>Nhà cung cấp</p>
                                    </a>
                                </li>
                            }
                            @if (HasPerm(Permissions.CustomerView))
                            {
                                <li class="nav-item">
                                    <a href="~/Customer" class="nav-link">
                                        <i class="nav-icon bi bi-people"></i>
                                        <p>Khách hàng</p>
                                    </a>
                                </li>
                            }
                            @if (HasPerm(Permissions.ShipperView))
                            {
                                <li class="nav-item">
                                    <a href="~/Shipper" class="nav-link">
                                        <i class="nav-icon bi bi-bicycle"></i>
                                        <p>Người giao hàng</p>
                                    </a>
                                </li>
                            }
                            @if (HasPerm(Permissions.EmployeeView))
                            {
                                <li class="nav-item">
                                    <a href="~/Employee" class="nav-link">
                                        <i class="nav-icon bi bi-people-fill"></i>
                                        <p>Nhân viên</p>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }

                @if (HasPerm(Permissions.CategoryView) || HasPerm(Permissions.ProductView))
                {
                    <li class="nav-item menu-open">
                        <a href="#" class="nav-link active">
                            <i class="nav-icon bi bi-archive"></i>
                            <p>
                                Quản lý hàng hóa
                                <i class="nav-arrow bi bi-chevron-right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            @if (HasPerm(Permissions.CategoryView))
                            {
                                <li class="nav-item">
                                    <a href="~/Category" class="nav-link">
                                        <i class="nav-icon bi bi-collection"></i>
                                        <p>Loại hàng</p>
                                    </a>
                                </li>
                            }
                            @if (HasPerm(Permissions.ProductView))
                            {
                                <li class="nav-item">
                                    <a href="~/Product" class="nav-link">
                                        <i class="nav-icon bi bi-boxes"></i>
                                        <p>Mặt hàng</p>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }

                @if (HasPerm(Permissions.OrderView) || HasPerm(Permissions.OrderCreate))
                {
                    <li class="nav-item menu-open">
                        <a href="#" class="nav-link active">
                            <i class="nav-icon bi bi-cash-stack"></i>
                            <p>
                                Quản lý bán hàng
                                <i class="nav-arrow bi bi-chevron-right"></i>
                            </p>
                        </a>
                        <ul class="nav nav-treeview">
                            @if (HasPerm(Permissions.OrderCreate))
                            {
                                <li class="nav-item">
                                    <a href="~/Order/Create" class="nav-link">
                                        <i class="nav-icon bi bi-cart-plus"></i>
                                        <p>Lập đơn hàng</p>
                                    </a>
                                </li>
                            }
                            @if (HasPerm(Permissions.OrderView))
                            {
                                <li class="nav-item">
                                    <a href="~/Order" class="nav-link">
                                        <i class="nav-icon bi bi-receipt"></i>
                                        <p>Quản lý đơn hàng</p>
                                    </a>
                                </li>
                            }
                        </ul>
                    </li>
                }
            </ul>
        </nav>
    </div>
</aside>
