@using System.Globalization
@using System.Security.Claims
@using SV22T1020073.Admin
@using SV22T1020073.Models.Constants
@{
    var employeeName = Context.Session.GetString("EmployeeName") ?? "Admin";
    var employeeEmail = Context.Session.GetString("EmployeeEmail") ?? "";
    var employeeId = Context.Session.GetInt32("EmployeeID");
    var roleNames = Context.Session.GetString("EmployeeRoles") ?? "";
    var roles = string.IsNullOrWhiteSpace(roleNames)
        ? new List<string>()
        : roleNames.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    var permissions = new List<string>();
    foreach (var role in roles)
    {
        var perms = Roles.GetPermissions(role);
        foreach (var perm in perms)
        {
            if (!permissions.Contains(perm))
                permissions.Add(perm);
        }
    }
    bool HasPerm(string p) => permissions.Contains(p);

    var cultureVi = CultureInfo.GetCultureInfo("vi-VN");
    string AvatarInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return string.Concat(char.ToUpper(parts[0][0], cultureVi), char.ToUpper(parts[^1][0], cultureVi));
        return char.ToUpper(parts[0][0], cultureVi).ToString();
    }

    var photoRaw = User.FindFirstValue("Photo")?.Trim() ?? "";
    var photoFile = photoRaw.Contains('/')
        ? photoRaw.Substring(photoRaw.LastIndexOf('/') + 1)
        : photoRaw;
    char[] invalidChars = { '<', '>', ':', '"', '|', '?', '*', '\\', '/' };
    var hasEmployeePhoto = !string.IsNullOrWhiteSpace(photoFile)
        && photoFile.IndexOfAny(invalidChars) < 0
        && !photoFile.Equals("nophoto.png", StringComparison.OrdinalIgnoreCase);
    var employeePhotoUrl = Url.Content("~/images/employees/" + photoFile);
    var nameForAvatar = User.FindFirstValue("DisplayName")
        ?? User.FindFirstValue(ClaimTypes.Name)
        ?? employeeName;
    var avatarInitials = AvatarInitials(nameForAvatar);
}
<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            @if (HasPerm(Permissions.DashboardView))
            {
                <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>
            }
        </ul>
        <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    @if (hasEmployeePhoto)
                    {
                        <img src="@employeePhotoUrl" class="user-image rounded-circle shadow" alt="" loading="lazy"
                             onerror="this.classList.add('d-none'); var n=this.nextElementSibling; if(n) n.classList.remove('d-none');" />
                        <span class="user-image rounded-circle shadow bg-primary text-white d-none d-inline-flex align-items-center justify-content-center fw-semibold user-avatar-initials--nav" title="@nameForAvatar">@avatarInitials</span>
                    }
                    else
                    {
                        <span class="user-image rounded-circle shadow bg-primary text-white d-inline-flex align-items-center justify-content-center fw-semibold user-avatar-initials--nav" title="@nameForAvatar">@avatarInitials</span>
                    }
                    <span class="d-none d-md-inline">@employeeName</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                    <li class="user-header text-bg-primary">
                        @if (hasEmployeePhoto)
                        {
                            <img src="@employeePhotoUrl" class="rounded-circle shadow" alt="" loading="lazy"
                                 onerror="this.classList.add('d-none'); var n=this.nextElementSibling; if(n) n.classList.remove('d-none');" />
                            <span class="rounded-circle shadow bg-primary text-white d-none d-inline-flex align-items-center justify-content-center fw-semibold user-avatar-initials--menu" title="@nameForAvatar">@avatarInitials</span>
                        }
                        else
                        {
                            <span class="rounded-circle shadow bg-primary text-white d-inline-flex align-items-center justify-content-center fw-semibold user-avatar-initials--menu" title="@nameForAvatar">@avatarInitials</span>
                        }
                        <p>
                            @employeeName
                            <small>@employeeEmail</small>
                        </p>
                    </li>
                    <li class="user-footer">
                        <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                        <a href="~/Account/Logout" class="btn btn-default btn-flat float-end">Thoát</a>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</nav>
