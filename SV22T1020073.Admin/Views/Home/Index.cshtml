@using SV22T1020073.DataLayers.Interfaces
@using SV22T1020073.Models.Sales
@{
    var todayRevenue = (decimal)ViewBag.TodayRevenue;
    var todayOrderCount = (int)ViewBag.TodayOrderCount;
    var orderCount = (int)ViewBag.OrderCount;
    var customerCount = (int)ViewBag.CustomerCount;
    var productCount = (int)ViewBag.ProductCount;
    var topProducts = ViewBag.TopProducts as List<ProductSalesRank> ?? new List<ProductSalesRank>();
    var pipelineOrders = ViewBag.PipelineOrders as List<OrderViewInfo> ?? new List<OrderViewInfo>();
    var monthlyRevenue = ViewBag.MonthlyRevenue as List<MonthlyRevenue>;
}

<!-- Thống kê nhanh -->
<div class="row">
    <div class="col-lg-3 col-6">
        <div class="card text-bg-primary">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">
                            Doanh thu hôm nay
                            <span class="ms-1 fw-bold" style="font-size: 1.15rem;">(@todayOrderCount)</span>
                        </h6>
                        <h3 class="mb-0">@todayRevenue.ToString("N0") đ</h3>
                    </div>
                    <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-success">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Đơn hàng</h6>
                        <h3 class="mb-0">@orderCount</h3>
                    </div>
                    <i class="bi bi-receipt fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-warning">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Khách hàng</h6>
                        <h3 class="mb-0">@customerCount</h3>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="card text-bg-danger">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="card-title">Sản phẩm</h6>
                        <h3 class="mb-0">@productCount</h3>
                    </div>
                    <i class="bi bi-box-seam fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Biểu đồ & thống kê -->
<div class="row mt-3">
    <div class="col-lg-8">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bar-chart me-1"></i>
                    Doanh thu theo tháng
                </h5>
            </div>
            <div class="card-body">
                <div class="position-relative dashboard-chart-wrap">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card card-info card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-star me-1"></i>
                    Top sản phẩm bán chạy
                </h5>
            </div>
            <div class="card-body p-0">
                @if (topProducts.Count > 0)
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var item in topProducts)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                @item.ProductName
                                <span class="badge bg-success">@item.QuantitySold</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="p-3 text-center text-muted">
                        <i class="bi bi-inbox fs-3 d-block mb-2"></i>
                        <p class="mb-0 small">Chưa có dữ liệu bán hàng</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Đơn hàng cần xử lý -->
<div class="row mt-3">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-clock-history me-1"></i>
                    Đơn hàng cần xử lý
                </h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày</th>
                            <th class="text-end">Tổng tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (pipelineOrders.Count > 0)
                        {
                            @foreach (var order in pipelineOrders)
                            {
                                <tr>
                                    <td>
                                        <a href="~/Order/Detail/@order.OrderID" class="text-decoration-none">#@order.OrderID</a>
                                    </td>
                                    <td>@order.CustomerName</td>
                                    <td>@order.OrderTime.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">@order.TotalAmount.ToString("N0") đ</td>
                                    <td>
                                        @if (order.Status == OrderStatusEnum.New)
                                        {
                                            <span class="badge bg-danger">Đang chờ duyệt</span>
                                        }
                                        else if (order.Status == OrderStatusEnum.Accepted)
                                        {
                                            <span class="badge bg-warning text-dark">Chờ giao hàng</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-check2-circle me-1"></i>
                                    Không có đơn hàng cần xử lý
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .dashboard-chart-wrap {
            height: 280px;
            min-height: 280px;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            const canvas = document.getElementById('revenueChart');
            if (!canvas || typeof Chart === 'undefined') return;

            const monthlyData = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(
                (monthlyRevenue ?? new List<MonthlyRevenue>())
                    .Select(m => new { month = m.Month, year = m.Year, revenue = m.Revenue }).ToList()
            ));

            const labels = monthlyData.map(m => 'Tháng ' + m.month + '/' + m.year);
            const revenues = monthlyData.map(m => Number(m.revenue) / 1000000);

            new Chart(canvas.getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Doanh thu (triệu đồng)',
                        data: revenues,
                        backgroundColor: 'rgba(13, 110, 253, 0.75)',
                        borderRadius: 6,
                        maxBarThickness: 56
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const v = context.parsed.y;
                                    return (typeof v === 'number' ? v.toFixed(2) : v) + ' triệu đồng';
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { display: false }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0 }
                        }
                    }
                }
            });
        })();
    </script>
}
